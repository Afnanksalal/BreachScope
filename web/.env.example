# ─── Database (Neon) ───────────────────────────────────────────────────────────
# Get from: console.neon.tech → your project → Connection string (pooled)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/breachscope?sslmode=require

# ─── NextAuth v5 ───────────────────────────────────────────────────────────────
# On Vercel, AUTH_URL is set automatically — only needed locally
AUTH_URL=http://localhost:3000
AUTH_SECRET=                  # openssl rand -base64 32

# ─── GitHub OAuth (optional — omit to disable GitHub login) ────────────────────
# Create at: github.com/settings/developers → OAuth Apps
# Callback URL: https://breachscoope.vercel.app/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ─── Google OAuth (optional — omit to disable Google login) ────────────────────
# Create at: console.cloud.google.com → APIs & Services → Credentials
# Callback URL: https://breachscoope.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── Encryption key (AES-256-GCM for stored API keys) ─────────────────────────
# Must be exactly 64 hex characters (32 bytes):  openssl rand -hex 32
ENCRYPTION_KEY=

# ─── App URL (returned to CLI during device flow) ─────────────────────────────
NEXT_PUBLIC_APP_URL=https://breachscoope.vercel.app
