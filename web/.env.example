# Database
DATABASE_URL=postgresql://user:password@host/breachscope?sslmode=require

# Auth.js / NextAuth
AUTH_URL=http://localhost:3000
AUTH_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OAuth providers are optional. Omit a provider pair to hide its login button.
# GitHub callback: <NEXT_PUBLIC_APP_URL>/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google callback: <NEXT_PUBLIC_APP_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# AES-256-GCM key for stored provider/API keys. Must be 64 hex characters.
ENCRYPTION_KEY=

# Distributed rate limiting. Recommended for production multi-instance deploys.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Integration delivery cron/job protection.
CRON_SECRET=

# Optional GitHub audit model override.
OPENAI_AUDIT_MODEL=

# Optional SCIM. Disabled unless ENABLE_SCIM=true and both values are set.
ENABLE_SCIM=false
SCIM_ORGANIZATION_ID=
SCIM_BEARER_TOKEN=

# Optional SAML metadata placeholders. ACS is fail-closed until validation is implemented.
SAML_ENTITY_ID=
SAML_ACS_URL=

# Optional identity integration records. Keep disabled unless the implementation is configured.
ENABLE_IDENTITY_INTEGRATIONS=false
